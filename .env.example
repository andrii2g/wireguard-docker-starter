# Public UDP port used by VPN clients.
# If your server is behind a router, forward this UDP port to the Docker host.
WG_PORT=51820

# Host TCP port for the wg-easy web UI.
# Keep this closed to the public internet unless you intentionally expose it.
WG_UI_PORT=51821

# Time zone used by the container.
TZ=UTC

# Allow plain HTTP access to the web UI.
# Required for the simple starter flow that opens http://SERVER_IP:WG_UI_PORT
# This is convenient but less secure than using HTTPS via reverse proxy.
INSECURE=true

# Enable unattended first-boot setup.
INIT_ENABLED=true

# Initial admin username and password.
# These are only used on the first container start.
# After successful bootstrap you may remove them for already-initialized deployments.
INIT_USERNAME=admin
INIT_PASSWORD=change-this-admin-password

# Public host and port that VPN clients will use to reach this server.
# These are only used on the first container start.
INIT_HOST=change-me.example.com
INIT_PORT=51820

# Optional initial global DNS setting pushed to clients.
# This is only used on the first container start.
INIT_DNS=1.1.1.1,8.8.8.8

# Optional initial network ranges.
# These are only used on the first container start.
# If you set one of these, set both.
INIT_IPV4_CIDR=10.8.0.0/24
INIT_IPV6_CIDR=fdcc:ad94:bacf:61a3::/64

# Local data directory persisted on the Docker host.
# This directory stores WireGuard keys, server config, and client data.
WG_DATA_DIR=./data/wireguard

# Compose project name.
COMPOSE_PROJECT_NAME=wireguard-docker-starter
